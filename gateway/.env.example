# Tokkatot Gateway Configuration (Zero-Config)
# Copy this file to .env and adjust as needed before running main.py

# URL of your Tokkatot Cloud instance (Middleware)
CLOUD_API_URL=https://app.tokkatot.com

# Local IP of the ESP32 controller
ESP32_IP=192.168.1.100

# How often to poll the ESP32 for readings (in seconds)
POLL_INTERVAL=5

# (Optional) Hardware identifier. If omitted, it will auto-detect the Raspberry Pi Serial / MAC
# HARDWARE_ID=PI_GATEWAY_001

# =========================================================================
# The following variables will be populated AUTOMATICALLY after 
# the gateway is claimed via the web dashboard. Do not set them manually!
# =========================================================================
# GATEWAY_TOKEN=
# FARM_ID=
# COOP_ID=
