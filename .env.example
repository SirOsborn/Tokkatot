# ================================================================
# TOKKATOT ENVIRONMENT TEMPLATE (.env.example)
# ================================================================

# ── ENVIRONMENT ────────────────────────────────────────────────
ENVIRONMENT=development
JWT_SECRET=your_long_random_jwt_secret_here

# ── DATABASE (Postgres) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=tokkatot
DB_PASSWORD=your_db_password_here
DB_NAME=tokkatot
DB_SSLMODE=disable

# ── SERVER ─────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ── INITIAL ADMIN ──────────────────────────────────────────────
INITIAL_ADMIN_EMAIL=admin@tokkatot.com
INITIAL_ADMIN_PASSWORD=your_admin_password_here

# ── TEST / STAGING FARMER (seeded in staging only, never hardcoded) ─
# Used by SeedTestData() and gateway-sim in staging environment.
# Leave blank in production .env to skip seeding entirely.
TEST_FARMER_EMAIL=farmer@tokkatot.com
TEST_FARMER_PASSWORD=your_test_farmer_password_here

# ── TELEMETRY & ANALYTICS ───────────────────────────────────────
TELEMETRY_RETENTION_DAYS=7

# ── WEB PUSH (VAPID) ────────────────────────────────────────────
# Generate these using go run middleware/scripts/generate_vapid/main.go
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tokkatot.com

# ── SIMULATOR / TELEMETRY ───────────────────────────────────────
CLOUD_API_URL=http://localhost:3000
GATEWAY_TOKEN=your_gateway_test_token_here

# ── DEMO FARM / COOP NAMES (optional, defaults below) ───────────
DEMO_FARM_NAME=Demo Farm
DEMO_COOP_NAME=Coop 1
