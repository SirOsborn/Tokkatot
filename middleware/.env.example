# Tokkatot Backend Environment Configuration
# Copy this file to .env and update values for your environment

# ===== DATABASE =====
DB_HOST=DB_HOST_HERE
DB_PORT=DB_PORT_HERE
DB_USER=DB_USER_HERE
DB_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
DB_NAME=DB_NAME_HERE
DB_SSLMODE=disable  # "disable" for local, "require" for production

# ===== SERVER =====
SERVER_PORT=SERVER_PORT_HERE
SERVER_HOST=SERVER_HOST_HERE

# ===== JWT & REGISTRATION =====
# CRITICAL: Generate random 32+ character secret for production
JWT_SECRET=CHANGE-ME-generate-with-openssl-rand-hex-32
REG_KEY=XXXXX-XXXXX-XXXXX-XXXXX-XXXXX

# ===== INITIAL ADMIN (Required for migrate_fresh) =====
INITIAL_ADMIN_EMAIL=INITIAL_ADMIN_EMAIL_HERE
INITIAL_ADMIN_PASSWORD=INITIAL_ADMIN_PASSWORD_HERE

# ===== TLS CERTIFICATES (Optional - for HTTPS) =====
TLS_CERT=../certs/cert.pem
TLS_KEY=../certs/key.pem

# ===== ENVIRONMENT =====
ENVIRONMENT=ENVIRONMENT_HERE  # "development" or "production"

# ===== WEB PUSH NOTIFICATIONS =====
# Generate keys once using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=VAPID_PUBLIC_KEY_HERE
VAPID_PRIVATE_KEY=VAPID_PRIVATE_KEY_HERE
VAPID_SUBJECT=mailto:admin@tokkatot.com
